# ── Claude API ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (SMS) ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX          # Your Twilio phone number

# ── Inbox to monitor (IMAP) ─────────────────────────────────────────────────────
# For Gmail: enable "App Passwords" (Google Account → Security → App Passwords)
IMAP_HOST=imap.gmail.com
IMAP_EMAIL=your@gmail.com
IMAP_PASSWORD=your-app-password          # 16-char Gmail App Password

# ── Outbound email (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=your-app-password          # Same App Password works for Gmail

# ── Reginald / Business ─────────────────────────────────────────────────────────
REGINALD_PHONE=+1XXXXXXXXXX             # Reginald's cell — gets a heads-up SMS
REGINALD_NAME=Reginald                  # Name used in outbound messages
BUSINESS_NAME=Treme Estate Sales

# ── Lead detection ──────────────────────────────────────────────────────────────
# Emails FROM this domain trigger Agent Shaka (comma-separated for multiple)
LEAD_SOURCE_DOMAINS=estatesales.net

# ── Timing ──────────────────────────────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=5                 # How often to poll inbox (default: 5s)

# ── Storage ─────────────────────────────────────────────────────────────────────
DB_PATH=agent_shaka.db
